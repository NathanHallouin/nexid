# Server
ENVIRONMENT=development
PORT=8080
VERSION=0.1.0

# Database (PostgreSQL)
DATABASE_URL=postgres://nexid:nexid@localhost:5432/nexid?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=generate-with-openssl-rand-base64-64
ENCRYPTION_KEY=generate-32-byte-key-for-aes256

# OAuth2
ISSUER=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_BURST=10

# Token TTL
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
